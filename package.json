{
  "name": "@platform/api-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Shared API client, Keycloak authentication config, and API type definitions for all Platform UI projects",
  "main": "./src/index.ts",
  "types": "./dist/types/index.d.ts",
  "files": [
    "src",
    "dist",
    "tsconfig.json",
    "tsconfig.build.json"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "axios": "^1.16.1",
    "keycloak-js": "^26.2.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "typescript": "~6.0.2"
  }
}
